#!/usr/bin/env bash
# qmd wrapper — runs @tobilu/qmd via bunx.
# Uses bunx directly if bun is on PATH (fast),
# falls back to nix run nixpkgs#bun (always works, slower on first fetch).
set -euo pipefail

# The helper can be reached through a vault-local .agents/skills symlink, so
# the script location is the skill install path, not necessarily the vault.
if [[ -n "${QMD_VAULT_ROOT:-}" ]]; then
    vault_root="$(cd -- "${QMD_VAULT_ROOT}" && pwd)"
elif git_root="$(git -C "${PWD}" rev-parse --show-toplevel 2>/dev/null)"; then
    vault_root="${git_root}"
else
    vault_root="${PWD}"
fi

state_dir="${QMD_STATE_DIR:-"${vault_root}/.qmd-agent"}"
config_dir="${QMD_CONFIG_DIR:-"${state_dir}/config"}"
cache_home="${XDG_CACHE_HOME:-"${state_dir}/cache"}"

mkdir -p "${config_dir}" "${cache_home}/qmd"

# Codex runs with a sandbox that may not be allowed to write ~/.config or
# ~/.cache. Keep QMD's mutable state inside the vault so semantic search works
# for agents without requiring an unsandboxed retry.
if [[ ! -f "${config_dir}/index.yml" ]]; then
    if [[ -f "${HOME}/.config/qmd/index.yml" ]] && grep -Fq "path: ${vault_root}" "${HOME}/.config/qmd/index.yml"; then
        cp "${HOME}/.config/qmd/index.yml" "${config_dir}/index.yml"
    else
        cat >"${config_dir}/index.yml" <<EOF
collections:
  vault:
    path: ${vault_root}
    pattern: "**/*.md"
    context:
      "": "Personal knowledge base: research notes, career, daily journals, web clippings"
EOF
    fi
fi

if [[ ! -f "${cache_home}/qmd/index.sqlite" && -f "${HOME}/.cache/qmd/index.sqlite" ]]; then
    cp "${HOME}/.cache/qmd/index.sqlite" "${cache_home}/qmd/index.sqlite"
fi

if [[ -d "${HOME}/.cache/qmd/models" ]]; then
    mkdir -p "${cache_home}/qmd/models"
    for model in "${HOME}/.cache/qmd/models"/*.gguf; do
        [[ -e "${model}" ]] || continue
        target="${cache_home}/qmd/models/$(basename "${model}")"
        if [[ ! -f "${target}" ]]; then
            cp "${model}" "${target}"
        fi
    done
fi

export QMD_CONFIG_DIR="${config_dir}"
export XDG_CACHE_HOME="${cache_home}"

if command -v bunx &>/dev/null; then
    exec bunx @tobilu/qmd "$@"
else
    exec nix run nixpkgs#bun -- x @tobilu/qmd "$@"
fi
