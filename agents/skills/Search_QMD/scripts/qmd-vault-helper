#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "click>=8.1,<9",
#   "rich>=13.7,<14",
# ]
# ///
"""Run QMD with mutable state scoped to an explicit vault root."""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import tempfile
from dataclasses import dataclass, replace
from pathlib import Path

import click
from rich.console import Console
from rich.table import Table

DEFAULT_PACKAGE = "@tobilu/qmd"
DEFAULT_LOCAL_BINARY = "qmd"
DEFAULT_INVOKE_METHOD = "local,bunx,nix"

HELP_CONTEXT = {"help_option_names": ["-h", "--help"]}
console = Console()

HELPER_OPTIONS = [
    (
        "vault_root",
        ("--vault-root",),
        "QMD_VAULT_ROOT",
        None,
        "Vault root to search. Required unless QMD_VAULT_ROOT is set.",
    ),
    (
        "invoke_method",
        ("--invoke-method",),
        "QMD_INVOKE_METHOD",
        DEFAULT_INVOKE_METHOD,
        "Method or comma-separated method list: local, bunx, nix, bun-bundle.",
    ),
    (
        "local_binary",
        ("--local-binary",),
        "QMD_LOCAL_BINARY",
        DEFAULT_LOCAL_BINARY,
        "Binary used by the local invocation method.",
    ),
    (
        "package",
        ("--package",),
        "QMD_PACKAGE",
        DEFAULT_PACKAGE,
        "Package used by bunx, nix, and bun-bundle methods.",
    ),
    (
        "package_root",
        ("--package-root",),
        "QMD_PACKAGE_ROOT",
        None,
        "Existing package root for bun-bundle compilation.",
    ),
    (
        "state_dir",
        ("--state-dir",),
        "QMD_STATE_DIR",
        None,
        "Directory for helper-managed QMD config/cache state.",
    ),
    (
        "config_dir",
        ("--config-dir",),
        "QMD_CONFIG_DIR",
        None,
        "QMD config directory. Default: <state-dir>/config.",
    ),
    (
        "cache_home",
        ("--cache-home",),
        "QMD_CACHE_HOME",
        None,
        "Cache root exported as XDG_CACHE_HOME.",
    ),
]


@dataclass
class HelperConfig:
    vault_root: str | None
    invoke_method: str
    local_binary: str
    package: str
    package_root: str | None
    state_dir: str | None
    config_dir: str | None
    cache_home: str | None

    def with_overrides(self, **values: str | None) -> "HelperConfig":
        updates = {key: value for key, value in values.items() if value is not None}
        return replace(self, **updates)


@dataclass(frozen=True)
class RuntimePaths:
    vault_root: Path
    state_dir: Path
    config_dir: Path
    cache_home: Path
    qmd_cache_dir: Path


def add_helper_options(include_env: bool):
    def decorator(command):
        for _name, flags, envvar, default, help_text in reversed(HELPER_OPTIONS):
            kwargs: dict[str, object] = {"help": help_text}
            if include_env:
                kwargs["envvar"] = envvar
                kwargs["default"] = default
                kwargs["show_default"] = default is not None
            command = click.option(*flags, **kwargs)(command)
        return command

    return decorator


@click.group(
    context_settings=HELP_CONTEXT,
    no_args_is_help=True,
    help=(
        "Run QMD against an explicit markdown vault.\n\n"
        "Use 'init' to prepare vault-scoped QMD state, then 'exec' to run QMD. "
        "Default invocation methods are local,bunx,nix; bun-bundle is explicit opt-in."
    ),
)
@add_helper_options(include_env=True)
@click.pass_context
def cli(
    ctx: click.Context,
    vault_root: str | None,
    invoke_method: str,
    local_binary: str,
    package: str,
    package_root: str | None,
    state_dir: str | None,
    config_dir: str | None,
    cache_home: str | None,
) -> None:
    ctx.obj = HelperConfig(
        vault_root=vault_root,
        invoke_method=invoke_method,
        local_binary=local_binary,
        package=package,
        package_root=package_root,
        state_dir=state_dir,
        config_dir=config_dir,
        cache_home=cache_home or os.environ.get("XDG_CACHE_HOME"),
    )


@cli.command(help="Create or refresh helper-managed QMD config/cache state.")
@add_helper_options(include_env=False)
@click.pass_obj
def init(
    config: HelperConfig,
    vault_root: str | None,
    invoke_method: str | None,
    local_binary: str | None,
    package: str | None,
    package_root: str | None,
    state_dir: str | None,
    config_dir: str | None,
    cache_home: str | None,
) -> None:
    config = config.with_overrides(
        vault_root=vault_root,
        invoke_method=invoke_method,
        local_binary=local_binary,
        package=package,
        package_root=package_root,
        state_dir=state_dir,
        config_dir=config_dir,
        cache_home=cache_home,
    )
    paths = initialize_state(config)
    print_init_summary(config, paths)


@cli.command(
    name="exec",
    add_help_option=False,
    context_settings={"ignore_unknown_options": True, "allow_extra_args": True},
    help="Initialize helper-managed state, then run QMD with the remaining args.",
)
@click.argument("qmd_args", nargs=-1, type=click.UNPROCESSED)
@click.pass_obj
def exec_qmd(config: HelperConfig, qmd_args: tuple[str, ...]) -> None:
    if not qmd_args:
        raise click.UsageError("exec requires QMD arguments.")
    paths = initialize_state(config)
    invoke_qmd(config, paths, list(qmd_args))


def resolve_paths(config: HelperConfig) -> RuntimePaths:
    if not config.vault_root:
        raise click.UsageError("vault root is required; pass --vault-root or QMD_VAULT_ROOT.")

    vault_root = Path(config.vault_root).expanduser()
    if not vault_root.is_dir():
        raise click.UsageError(f"vault root is not a directory: {vault_root}")
    vault_root = vault_root.resolve()

    state_dir = Path(config.state_dir).expanduser() if config.state_dir else vault_root / ".qmd-agent"
    config_dir = Path(config.config_dir).expanduser() if config.config_dir else state_dir / "config"
    cache_home = Path(config.cache_home).expanduser() if config.cache_home else state_dir / "cache"

    return RuntimePaths(
        vault_root=vault_root,
        state_dir=state_dir,
        config_dir=config_dir,
        cache_home=cache_home,
        qmd_cache_dir=cache_home / "qmd",
    )


def initialize_state(config: HelperConfig) -> RuntimePaths:
    paths = resolve_paths(config)
    paths.config_dir.mkdir(parents=True, exist_ok=True)
    paths.qmd_cache_dir.mkdir(parents=True, exist_ok=True)

    config_file = paths.config_dir / "index.yml"
    home_config = Path.home() / ".config" / "qmd" / "index.yml"
    home_config_matches = False

    if home_config.exists():
        text = home_config.read_text(encoding="utf-8", errors="ignore")
        home_config_matches = f"path: {paths.vault_root}" in text

    if not config_file.exists():
        if home_config_matches:
            shutil.copy2(home_config, config_file)
        else:
            write_default_index(config_file, paths.vault_root)

    cache_index = paths.qmd_cache_dir / "index.sqlite"
    home_cache_index = Path.home() / ".cache" / "qmd" / "index.sqlite"
    if home_config_matches and not cache_index.exists() and home_cache_index.exists():
        shutil.copy2(home_cache_index, cache_index)

    copy_cached_models(paths)
    return paths


def print_init_summary(config: HelperConfig, paths: RuntimePaths) -> None:
    table = Table(show_header=False, box=None, padding=(0, 2))
    table.add_column("setting", style="bold cyan", no_wrap=True)
    table.add_column("value", overflow="fold")
    table.add_row("vault_root", str(paths.vault_root))
    table.add_row("state_dir", str(paths.state_dir))
    table.add_row("qmd_config_dir", str(paths.config_dir))
    table.add_row("xdg_cache_home", str(paths.cache_home))
    table.add_row("invoke_method", ",".join(split_methods(config.invoke_method)))

    console.print("[bold green]qmd-vault-helper initialized[/]")
    console.print(table)


def write_default_index(config_file: Path, vault_root: Path) -> None:
    config_file.write_text(
        "\n".join(
            [
                "collections:",
                "  vault:",
                f"    path: {vault_root}",
                '    pattern: "**/*.md"',
                "    context:",
                '      "": "Personal knowledge base: research notes, career, daily journals, web clippings"',
                "",
            ]
        ),
        encoding="utf-8",
    )


def copy_cached_models(paths: RuntimePaths) -> None:
    home_models = Path.home() / ".cache" / "qmd" / "models"
    if not home_models.is_dir():
        return

    model_dir = paths.qmd_cache_dir / "models"
    model_dir.mkdir(parents=True, exist_ok=True)
    for model in home_models.glob("*.gguf"):
        target = model_dir / model.name
        if not target.exists():
            shutil.copy2(model, target)


def qmd_env(paths: RuntimePaths) -> dict[str, str]:
    env = os.environ.copy()
    env["QMD_CONFIG_DIR"] = str(paths.config_dir)
    env["XDG_CACHE_HOME"] = str(paths.cache_home)
    return env


def package_root_from_local_binary(binary: str) -> Path | None:
    binary_path = shutil.which(binary)
    if not binary_path:
        return None

    package_root = Path(binary_path).resolve().parent.parent
    if (package_root / "dist" / "cli" / "qmd.js").is_file():
        return package_root
    return None


def resolve_configured_package_root(config: HelperConfig) -> Path | None:
    if config.package_root:
        package_root = Path(config.package_root).expanduser().resolve()
        if (package_root / "dist" / "cli" / "qmd.js").is_file():
            return package_root
        raise click.ClickException(
            f"QMD package root does not contain dist/cli/qmd.js: {package_root}"
        )
    return None


def cached_package_bundle(config: HelperConfig, paths: RuntimePaths) -> Path | None:
    pointer = bundle_pointer_file(config, paths)
    if not pointer.is_file():
        return None
    target = Path(pointer.read_text(encoding="utf-8").strip())
    if compiled_bundle_ok(target, f"package:{config.package}"):
        return target
    return None


def bundle_pointer_file(config: HelperConfig, paths: RuntimePaths) -> Path:
    return paths.qmd_cache_dir / "bin" / f"{safe_package_name(config.package)}.current"


def safe_package_name(package: str) -> str:
    return "".join(char if char.isalnum() else "-" for char in package).strip("-") or "qmd"


def compiled_bundle_ok(compiled: Path, stamp_label: str) -> bool:
    stamp = Path(f"{compiled}.source")
    smoke_stamp = Path(f"{compiled}.smoke-ok")
    return (
        compiled.is_file()
        and os.access(compiled, os.X_OK)
        and stamp.is_file()
        and smoke_stamp.is_file()
        and stamp.read_text(encoding="utf-8").strip() == stamp_label
    )


def find_package_root_in_source(source_dir: Path, package: str) -> Path:
    package_root = source_dir / "node_modules" / Path(package)
    if (package_root / "dist" / "cli" / "qmd.js").is_file():
        return package_root
    raise click.ClickException(f"unable to locate {package} after temporary install.")


def install_package_to_temp_source(config: HelperConfig, paths: RuntimePaths) -> tuple[tempfile.TemporaryDirectory[str], Path]:
    bun = shutil.which("bun")
    if not bun:
        raise click.ClickException("bun is required to install QMD for bun-bundle.")

    source_parent = paths.qmd_cache_dir / "bundle-source"
    source_parent.mkdir(parents=True, exist_ok=True)
    temp_source = tempfile.TemporaryDirectory(prefix="qmd-source-", dir=source_parent)
    source_dir = Path(temp_source.name)
    subprocess.run(
        [bun, "add", config.package],
        cwd=source_dir,
        stdout=subprocess.DEVNULL,
        check=True,
    )
    return temp_source, find_package_root_in_source(source_dir, config.package)


def source_package_root(config: HelperConfig, paths: RuntimePaths) -> tuple[Path, str] | None:
    package_root = resolve_configured_package_root(config)
    if package_root:
        return package_root, str(package_root)

    package_root = package_root_from_local_binary(config.local_binary)
    if package_root:
        return package_root, str(package_root)

    return None


def package_version(package_root: Path) -> str:
    try:
        metadata = json.loads((package_root / "package.json").read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return "unknown"
    version = metadata.get("version")
    return version if isinstance(version, str) and version else "unknown"


def compile_bun_bundle(
    package_root: Path,
    compiled: Path,
    stamp_label: str,
    env: dict[str, str],
) -> Path:
    stamp = Path(f"{compiled}.source")
    smoke_stamp = Path(f"{compiled}.smoke-ok")

    if compiled_bundle_ok(compiled, stamp_label):
        return compiled

    bun = shutil.which("bun")
    if not bun:
        raise click.ClickException("bun not found on PATH.")

    compiled.parent.mkdir(parents=True, exist_ok=True)
    tmp = compiled.with_name(f"{compiled.name}.tmp.{os.getpid()}")
    try:
        subprocess.run(
            [
                bun,
                "build",
                "--compile",
                "--external",
                "@node-llama-cpp/*",
                "--external",
                "sqlite-vec-*",
                "dist/cli/qmd.js",
                "--outfile",
                str(tmp),
            ],
            cwd=package_root,
            stdout=subprocess.DEVNULL,
            check=True,
        )
        tmp.replace(compiled)
        compiled.chmod(0o755)
        smoke = subprocess.run(
            [str(compiled), "--help"],
            env=env,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if smoke.returncode != 0:
            raise click.ClickException(
                f"bun-bundled QMD executable failed smoke test: {compiled}"
            )
        stamp.write_text(f"{stamp_label}\n", encoding="utf-8")
        smoke_stamp.write_text("ok\n", encoding="utf-8")
        return compiled
    finally:
        tmp.unlink(missing_ok=True)


def ensure_bun_bundle(config: HelperConfig, paths: RuntimePaths, env: dict[str, str]) -> Path:
    compiled_dir = paths.qmd_cache_dir / "bin"
    compiled_dir.mkdir(parents=True, exist_ok=True)

    source = source_package_root(config, paths)
    if source:
        package_root, stamp_label = source
        compiled = compiled_dir / f"qmd-{safe_package_name(config.package)}-{package_version(package_root)}"
        return compile_bun_bundle(package_root, compiled, stamp_label, env)

    cached = cached_package_bundle(config, paths)
    if cached:
        return cached

    temp_source, package_root = install_package_to_temp_source(config, paths)
    with temp_source:
        version = package_version(package_root)
        compiled = compiled_dir / f"qmd-{safe_package_name(config.package)}-{version}"
        compiled = compile_bun_bundle(package_root, compiled, f"package:{config.package}", env)
        bundle_pointer_file(config, paths).write_text(f"{compiled}\n", encoding="utf-8")
        return compiled


def exec_program(argv: list[str], env: dict[str, str]) -> None:
    os.execvpe(argv[0], argv, env)


def invoke_qmd(config: HelperConfig, paths: RuntimePaths, qmd_args: list[str]) -> None:
    env = qmd_env(paths)
    errors: list[str] = []

    for method in split_methods(config.invoke_method):
        if method == "local":
            binary = shutil.which(config.local_binary)
            if binary:
                exec_program([binary, *qmd_args], env)
            errors.append(f"local: {config.local_binary} not found on PATH")
        elif method == "bunx":
            bunx = shutil.which("bunx")
            if bunx:
                exec_program([bunx, config.package, *qmd_args], env)
            bun = shutil.which("bun")
            if bun:
                exec_program([bun, "x", config.package, *qmd_args], env)
            errors.append("bunx: neither bunx nor bun found on PATH")
        elif method == "nix":
            nix = shutil.which("nix")
            if nix:
                exec_program([nix, "run", "nixpkgs#bun", "--", "x", config.package, *qmd_args], env)
            errors.append("nix: nix not found on PATH")
        elif method == "bun-bundle":
            try:
                exec_program([str(ensure_bun_bundle(config, paths, env)), *qmd_args], env)
            except (OSError, subprocess.CalledProcessError, click.ClickException) as error:
                errors.append(f"bun-bundle: {error}")
        else:
            raise click.UsageError(
                f"unsupported invocation method {method!r}; "
                "supported methods are local, bunx, nix, bun-bundle."
            )

    raise click.ClickException(
        "no QMD invocation method succeeded:\n"
        + "\n".join(f"  - {error}" for error in errors)
    )


def split_methods(value: str) -> list[str]:
    methods = [method.strip() for method in value.split(",") if method.strip()]
    if not methods:
        raise click.UsageError("--invoke-method must include at least one method.")
    return methods


if __name__ == "__main__":
    cli()
